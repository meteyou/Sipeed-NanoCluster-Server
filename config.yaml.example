server:
  host: "0.0.0.0"
  port: 5000

temperature_monitoring:
  interval_seconds: 30
  endpoint: "/api/temperature"
  timeout: 5

nodes:
  - name: "node-1"
    description: "Raspberry Pi CM4, 8GB RAM"
    slot: 1
    ip: "192.168.0.101"
    port: 5001
    enabled: true

  - name: "node-2"
    description: "Raspberry Pi CM4, 4GB RAM"
    slot: 2
    ip: "192.168.0.102"
    port: 5001
    enabled: true

  - name: "node-3"
    description: "LicheeRV Nano"
    slot: 3
    ip: "192.168.0.103"
    port: 5001
    enabled: false

fan:
  gpio_chip: 0              # GPIO chip number (0 for Pi 4, 4 for Pi 5)
  gpio_pin: 13
  min_temp: 40
  max_temp: 70
  min_speed: 30
  max_speed: 100
  pwm_frequency: 50
  pwm_reverse: false
